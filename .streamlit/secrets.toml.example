# Streamlit Secrets Template for NEXUS Terminal
# =============================================
# Copy this content to your Streamlit Cloud app settings:
# Settings > Secrets > Add your secrets
#
# Or for local development, create .streamlit/secrets.toml with this content

# Required for Oracle AI Chat feature
GROQ_API_KEY = "your-groq-api-key-here"

# Optional: Polymarket API credentials (not required for basic functionality)
# POLY_API_KEY = "your-polymarket-api-key"
# POLY_SECRET = "your-polymarket-secret"
# POLY_PASSPHRASE = "your-polymarket-passphrase"
# POLY_PRIVATE_KEY = "your-polymarket-private-key"
