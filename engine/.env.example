# =============================================================================
# YHack 2026 - Crypto Trading Research System
# Environment Variables Template
# =============================================================================
# 
# Instructions:
# 1. Copy this file to 'credentials.env' in the same directory
# 2. Replace the placeholder values with your actual API keys
# 3. NEVER commit credentials.env to version control
#
# =============================================================================

# -----------------------------------------------------------------------------
# Polymarket API Credentials
# Get your keys from: https://polymarket.com (Account Settings > API)
# -----------------------------------------------------------------------------
POLY_API_KEY=your_polymarket_api_key_here
POLY_SECRET=your_polymarket_secret_here
POLY_PASSPHRASE=your_polymarket_passphrase_here

# -----------------------------------------------------------------------------
# Groq API Key (for Oracle AI / LLM features)
# Get your key from: https://console.groq.com/keys
# -----------------------------------------------------------------------------
GROQ_API_KEY=your_groq_api_key_here

# -----------------------------------------------------------------------------
# Optional: Polymarket Private Key (for on-chain transactions)
# Only needed if you want to execute real trades
# -----------------------------------------------------------------------------
# POLY_PRIVATE_KEY=your_wallet_private_key_here
